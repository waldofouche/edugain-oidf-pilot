##
## Velocity Template for DisplayUsernamePasswordPage view-state
##

#set ($nonce = $cspNonce.generateIdentifier())
#set ($onClick = "this.innerText='Logging in...'")

$response.addHeader(
    "Content-Security-Policy",
    "script-src-elem 'nonce-$nonce' https://cdn.tailwindcss.com; script-src-attr 'unsafe-hashes' 'sha256-$cspDigester.apply($onClick)'"
)

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>#springMessageText("idp.title", "Web Login Service")</title>

    <script #if ($nonce)nonce="$nonce"#end src="https://cdn.tailwindcss.com"></script>

    <style>
        body {
            font-family: Inter, system-ui, sans-serif;
        }
    </style>
</head>

<body class="min-h-screen bg-slate-100 flex flex-col">

<main class="flex-1 flex items-center justify-center px-4 py-10">

    <div class="w-full max-w-md">

        <!-- Login Card -->
        <div class="bg-white rounded-2xl shadow-xl border border-slate-200 overflow-hidden">

            <!-- Header -->
            <div class="bg-slate-900 px-8 py-6 text-white">

                <div class="flex items-center gap-4">

                    <img
                            class="w-14 h-14 object-contain rounded-lg bg-white p-2"
                            src="$request.getContextPath()#springMessageText('idp.logo', '/images/placeholder-logo.png')"
                            alt="#springMessageText('idp.logo.alt-text', 'logo')"
                    />

                    <div>
                        #set ($serviceName = $rpUIContext.serviceName)

                        #if ($serviceName && !$rpContext.getRelyingPartyId().contains($serviceName))
                            <h1 class="text-2xl font-semibold leading-tight">
                                $encoder.encodeForHTML($serviceName)
                            </h1>
                            <p class="text-slate-300 text-sm mt-1">
                                Sign in to continue
                            </p>
                        #else
                            <h1 class="text-2xl font-semibold">
                                #springMessageText("idp.title", "Web Login Service")
                            </h1>
                        #end
                    </div>

                </div>
            </div>

            <!-- Form -->
            <div class="px-8 py-8">

                #set ($logo = $rpUIContext.getLogo())
                #if ($logo)
                    <div class="mb-6 text-center">
                        <img
                                class="mx-auto max-h-16 object-contain"
                                src="$encoder.encodeForHTMLAttribute($logo)"
                                alt="$encoder.encodeForHTMLAttribute($serviceName)"
                        />
                    </div>
                #end

                #set ($desc = $rpUIContext.getServiceDescription())
                #if ($desc)
                    <div class="mb-6 text-sm text-slate-600 text-center">
                        $encoder.encodeForHTML($desc)
                    </div>
                #end

                #set ($errorMessage = $errorMessageFunction.apply($profileRequestContext))
                #if ($errorMessage)
                    <div class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                        $encoder.encodeForHTML($errorMessage)
                    </div>
                #end

                <form action="$flowExecutionUrl" method="post" class="space-y-5">

                    #parse("csrf/csrf.vm")

                    <!-- Username -->
                    <div>
                        <label
                                for="username"
                                class="block text-sm font-medium text-slate-700 mb-2"
                        >
                            #springMessageText("idp.login.username", "Username")
                        </label>

                        <input
                                id="username"
                                name="j_username"
                                type="text"
                                autocomplete="username"
                                value="#if($username)$encoder.encodeForHTML($username)#end"
                                class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm outline-none transition focus:border-blue-500 focus:ring-4 focus:ring-blue-100"
                                placeholder="Enter your username"
                                required
                        />
                    </div>

                    <!-- Password -->
                    <div>
                        <label
                                for="password"
                                class="block text-sm font-medium text-slate-700 mb-2"
                        >
                            #springMessageText("idp.login.password", "Password")
                        </label>

                        <input
                                id="password"
                                name="j_password"
                                type="password"
                                autocomplete="current-password"
                                class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm outline-none transition focus:border-blue-500 focus:ring-4 focus:ring-blue-100"
                                placeholder="Enter your password"
                                required
                        />
                    </div>

                    <!-- Options -->
                    <div class="space-y-3">

                        #if (!$authenticationContext.getActiveResults().containsKey('authn/Password'))
                            <label class="flex items-start gap-3 text-sm text-slate-700">
                                <input
                                        type="checkbox"
                                        name="donotcache"
                                        value="1"
                                        id="donotcache"
                                        class="mt-1 h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500"
                                />

                                <span>
                                    #springMessageText(
                                            "idp.login.donotcache",
                                        "Don't remember login"
                                        )
                                </span>
                            </label>
                        #end

                        <label class="flex items-start gap-3 text-sm text-slate-700">
                            <input
                                    id="_shib_idp_revokeConsent"
                                    type="checkbox"
                                    name="_shib_idp_revokeConsent"
                                    value="true"
                                    class="mt-1 h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500"
                            />

                            <span>
                                #springMessageText(
                                        "idp.attribute-release.revoke",
                                    "Clear prior granting of permission for release of your information to this service."
                                    )
                            </span>
                        </label>

                    </div>

                    <!-- Submit -->
                    <button
                            type="submit"
                            name="_eventId_proceed"
                            onClick="$onClick"
                            class="w-full rounded-xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white shadow-lg transition hover:bg-slate-800 focus:outline-none focus:ring-4 focus:ring-slate-300"
                    >
                        #springMessageText("idp.login.login", "Login")
                    </button>

                </form>

                <!-- Links -->
                <div class="mt-6 border-t border-slate-200 pt-5">

                    <ul class="space-y-3 text-sm">

                        <li>
                            <a
                                    href="#springMessageText('idp.url.password.reset', '#')"
                                    class="text-blue-600 hover:text-blue-800 hover:underline"
                            >
                                #springMessageText(
                                        "idp.login.forgotPassword",
                                    "Forgot your password?"
                                    )
                            </a>
                        </li>

                        <li>
                            <a
                                    href="#springMessageText('idp.url.helpdesk', '#')"
                                    class="text-blue-600 hover:text-blue-800 hover:underline"
                            >
                                #springMessageText(
                                        "idp.login.needHelp",
                                    "Need Help?"
                                    )
                            </a>
                        </li>

                    </ul>

                </div>

            </div>

        </div>

        <!-- Footer -->
        <footer class="mt-8 text-center text-sm text-slate-500">
            <p>
                #springMessageText(
                        "idp.footer",
                    "© 2026 Your Organisation. All rights reserved."
                    )
            </p>
        </footer>

    </div>

</main>

<!-- Autofocus -->
<script #if ($nonce)nonce="$nonce"#end>
    const ufield = document.getElementById('username');
    const pfield = document.getElementById('password');

    if (ufield.value.trim().length === 0) {
        ufield.focus();
    } else {
        pfield.focus();
    }
</script>

</body>
</html>